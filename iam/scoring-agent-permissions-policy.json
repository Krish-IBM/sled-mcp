{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "*"
    },
    {
      "Sid": "S3ProjectDocsAndOutputs",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::sled-scoring-agent-bucket",
        "arn:aws:s3:::sled-scoring-agent-bucket/*"
      ]
    },
    {
      "Sid": "S3CIBucketRead",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::competitive-intelligence-sled",
        "arn:aws:s3:::competitive-intelligence-sled/*"
      ]
    },
    {
      "Sid": "BedrockClaude",
      "Effect": "Allow",
      "Action": ["bedrock:InvokeModel", "bedrock:InvokeModelWithResponseStream"],
      "Resource": "*"
    },
    {
      "Sid": "TextractOCR",
      "Effect": "Allow",
      "Action": ["textract:StartDocumentTextDetection", "textract:GetDocumentTextDetection"],
      "Resource": "*"
    },
    {
      "Sid": "SelfInvokeForAsyncJobs",
      "Effect": "Allow",
      "Action": ["lambda:InvokeFunction"],
      "Resource": "arn:aws:lambda:us-east-1:211125468742:function:sled-scoring-agent"
    }
  ]
}
