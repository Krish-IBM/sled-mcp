# ============================================================================
#  SLED MCP router + Scoring agent — environment variable template
# ============================================================================
#  Copy to `.env` and fill in real values for local development:
#
#      cp .env.example .env
#
#  `.env` is gitignored and loaded by env_config.py for local runs/tests only.
#  In AWS Lambda these come from each function's configured environment vars
#  (set by deploy.sh / deploy_scoring.sh), not from any file.
# ============================================================================

# ── MCP router (lambda_handler.py): IBM w3id auth ───────────────────────────
W3ID_ISSUER=https://login.w3.ibm.com/oidc/endpoint/default
W3ID_JWKS_URI=https://login.w3.ibm.com/v1.0/endpoint/default/jwks
# Required (no code default) — full w3id client_id
W3ID_AUDIENCE=CHANGE_ME
# Defaults to W3ID_AUDIENCE if left blank
W3ID_CLIENT_ID=
# Secrets Manager ARN of the w3id client secret (the secret itself is NOT stored here)
W3ID_CLIENT_SECRET_ARN=arn:aws:secretsmanager:us-east-1:<account-id>:secret:sled-mcp/w3id-client-secret-XXXXXX
W3ID_INTROSPECTION_URL=https://login.w3.ibm.com/v1.0/endpoint/default/introspect
W3ID_SCOPES_SUPPORTED=openid

# ── MCP router: introspection cache ─────────────────────────────────────────
INTROSPECTION_CACHE_TTL=300
INTROSPECTION_CACHE_MAX=1000

# ── MCP router: backend agent URLs ──────────────────────────────────────────
# Required (no code default)
SLED_DOCS_QUERY_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/sled-docs-query/sled-docs-query
SCORING_AGENT_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/
ANALYZE_DEAL_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/analyze-deal-and-upload/analyze-deal
BID_ANALYSIS_AGENT_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/
COMPETITOR_ANALYSIS_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/
GENERAL_AGENT_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/

# ── MCP router: routing + hosting ───────────────────────────────────────────
# Catch-all for queries matching no specialist. 'general' answers anything;
# falls through to the first configured agent if GENERAL_AGENT_URL is unset.
DEFAULT_AGENT=general
# 1/true/yes to enable stateful sessions
MCP_STATEFUL_SESSIONS=
API_HOST=<api-id>.execute-api.us-east-1.amazonaws.com
STAGE=prod
# Override the self-derived public base URL (blank = auto-derive)
PUBLIC_BASE_URL=

# ── Legacy SSE handler (lambda_handler_sse.py) ──────────────────────────────
COGNITO_TOKEN_URL=

# ── Scoring agent (scoring_agent/handler.py): storage ───────────────────────
# Required for scoring
SCORING_BUCKET=your-scoring-bucket
# Defaults to SCORING_BUCKET if left blank
SCORING_OUTPUT_BUCKET=
JOBS_PREFIX=jobs/
OUTPUT_PREFIX=outputs/
PRESIGN_TTL=3600
SELF_FUNCTION_NAME=sled-scoring-agent

# ── Scoring agent: competitive-intelligence source (deal= scoring) ──────────
CI_BUCKET=competitive-intelligence-sled
CI_DEALS_PREFIX=

# ── Scoring agent: output deck ──────────────────────────────────────────────
DEFAULT_FOCAL=IBM
# 1/true/yes to render the PPTX deck
SCORING_PPTX_ENABLED=
SCORING_PPTX_TEMPLATE_S3=
SCORING_PPTX_TEMPLATE_PATH=

# ── Scoring agent: time budget (seconds) ────────────────────────────────────
RENDER_MARGIN_SECONDS=300
JOB_STALE_GRACE_SECONDS=30
DEFAULT_LAMBDA_BUDGET_SECONDS=900

# ── Scoring agent: document ingest limits ───────────────────────────────────
SCORING_MAX_OCR_PAGES_PER_DOC=60
SCORING_MAX_DOCS=60
SCORING_MAX_TOTAL_MB=400

# ── Scoring agent: Bedrock (models + client) ────────────────────────────────
SCORING_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
SCORING_FAST_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_RETRIES=3
BEDROCK_CONNECT_TIMEOUT=10
BEDROCK_READ_TIMEOUT=60

# ── General agent (general_agent/handler.py): catch-all Q&A ─────────────────
GENERAL_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
GENERAL_KB_ID=FIFNL0U11I
# Relevance floor (0-1) for the direct KB-retrieve path
GENERAL_RETRIEVE_MIN_SCORE=0.4
# Answer length cap
GENERAL_MAX_TOKENS=2000
# SLED_DOCS_QUERY_URL (above) doubles as the corpus fallback when retrieve is denied

# ── Competitor-analysis agent (competitor_analysis/handler.py) ──────────────
# Required for competitor analysis (job records + JSON/DOCX outputs)
CA_OUTPUT_BUCKET=sled-scoring-agent-bucket
CA_JOBS_PREFIX=competitor-analysis/jobs/
CA_OUTPUT_PREFIX=competitor-analysis/outputs/
CA_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
CA_FAST_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# Budget knobs (defaults shown)
CA_MAX_PROCUREMENTS=25
CA_MAX_DOCS_PER_PROC=6
CA_MAX_CHARS_PER_DIGEST=150000
CA_MAX_CHARS_PER_DOC=60000
CA_MAX_DOC_MB=150

# ── AWS (normally provided by the runtime / your CLI profile) ───────────────
# AWS_REGION=us-east-1
